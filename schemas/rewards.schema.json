{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "theworkshop.rewards.v1",
  "type": "object",
  "required": ["schema", "generated_at", "project", "jobs"],
  "properties": {
    "schema": { "type": "string" },
    "generated_at": { "type": "string" },
    "project": { "type": "string" },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["work_item_id", "reward_score", "reward_target", "gate_passed", "next_action"],
        "properties": {
          "work_item_id": { "type": "string" },
          "reward_score": { "type": "integer" },
          "reward_target": { "type": "integer" },
          "gate_passed": { "type": "boolean" },
          "next_action": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
