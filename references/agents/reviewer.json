{
  "schema": "theworkshop.agentprofile.v1",
  "name": "theworkshop_reviewer",
  "legacy_aliases": ["reviewer", "review", "qa", "verify", "closeout"],
  "runtime_agent_name": "theworkshop_reviewer",
  "builtin_fallback_agent_type": "default",
  "agent_type": "default",
  "description": "Verification and synthesis profile for QA-heavy or high-risk closeout tasks.",
  "default_for": {
    "stakes": ["high", "critical"],
    "orchestration_mode": ["review", "verify", "qa", "closeout"]
  },
  "execution": {
    "default_dispatch_budget": 1,
    "default_retry_limit": 1,
    "preferred_parallel_group_size": 1,
    "notes": "Use when jobs require independent verification and final synthesis."
  }
}
